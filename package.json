{
    "name": "root",
    "private": true,
    "version": "1.13.0",
    "type": "module",
    "description": "AI-powered UI agent for web applications",
    "author": "Simon<gaomeng1900>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/alibaba/page-agent.git"
    },
    "homepage": "https://alibaba.github.io/page-agent/",
    "packageManager": "pnpm@11.7.0",
    "engines": {
        "node": ">=22",
        "pnpm": "^11.7.0"
    },
    "scripts": {
        "dev:ext": "pnpm --filter @kylebrodeur/page-agent-ext dev",
        "dev:demo": "pnpm --filter @kylebrodeur/page-agent dev:demo",
        "build": "pnpm run cleanup && pnpm -r --if-present run build && pnpm run build:ext",
        "build:libs": "pnpm -r --if-present run build",
        "build:ext": "pnpm --filter @kylebrodeur/page-agent-ext zip",
        "version": "node scripts/sync-version.js",
        "postpublish": "pnpm -r --if-present run postpublish",
        "publish:libs": "node scripts/publish.js",
        "publish:libs:dry": "node scripts/publish.js --dry-run",
        "typecheck": "tsc --noEmit -p tsconfig.typecheck.json && tsc --noEmit -p packages/extension/tsconfig.json",
        "test": "pnpm -r --if-present run test",
        "lint": "eslint .",
        "ci": "node scripts/ci.js",
        "cleanup": "rm -rf packages/*/dist && rm -rf packages/*/.output",
        "prepare": "husky || true"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.2.0",
        "@commitlint/config-conventional": "^21.2.0",
        "@eslint-react/eslint-plugin": "^5.11.2",
        "@eslint/js": "^10.0.1",
        "@microsoft/api-extractor": "^7.58.9",
        "@tailwindcss/vite": "^4.3.2",
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/node": "^26.1.0",
        "@vitejs/plugin-react": "^6.0.3",
        "chalk": "^5.6.2",
        "concurrently": "^10.0.3",
        "dotenv": "^17.4.2",
        "eslint": "^10.6.0",
        "globals": "^17.7.0",
        "happy-dom": "^20.10.6",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.8",
        "prettier": "^3.9.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.63.0",
        "unplugin-dts": "^1.0.3",
        "vite": "^8.1.3",
        "vite-plugin-css-injected-by-js": "^5.0.1",
        "vitest": "^4.1.10"
    },
    "overrides": {
        "typescript": "^6.0.3"
    },
    "lint-staged": {
        "*.{js,ts,cjs,cts,mjs,mts}": [
            "pnpm exec prettier --write --ignore-unknown",
            "pnpm exec eslint --quiet"
        ],
        "*.{jsx,tsx}": [
            "pnpm exec prettier --write --ignore-unknown",
            "pnpm exec eslint --quiet"
        ],
        "*.css": [
            "pnpm exec prettier --write --ignore-unknown"
        ],
        "*.md": [
            "pnpm exec prettier --write --ignore-unknown"
        ]
    },
    "commitlint": {
        "extends": [
            "@commitlint/config-conventional"
        ],
        "rules": {
            "subject-case": [
                0,
                "never"
            ]
        }
    },
    "prettier": {
        "singleQuote": true,
        "semi": false,
        "useTabs": true,
        "printWidth": 100,
        "trailingComma": "es5",
        "plugins": [
            "@trivago/prettier-plugin-sort-imports"
        ],
        "importOrder": [
            "<THIRD_PARTY_MODULES>",
            "^(@/).*(?<!css)$",
            "^[./].*(?<!css)$",
            ".css$"
        ],
        "importOrderSeparation": true,
        "importOrderSortSpecifiers": true,
        "overrides": [
            {
                "files": "*.md",
                "options": {
                    "useTabs": false,
                    "tabWidth": 4
                }
            },
            {
                "files": "*.json",
                "options": {
                    "useTabs": false,
                    "tabWidth": 4
                }
            }
        ]
    }
}
